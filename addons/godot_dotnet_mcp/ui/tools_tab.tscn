[gd_scene format=3 uid="uid://cxcsjc8225x3f"]

[ext_resource type="Script" uid="uid://dgj3nw3kbbfdq" path="res://addons/godot_dotnet_mcp/ui/tools_tab.gd" id="1"]

[sub_resource type="Shader" id="Shader_pyddu"]
code = "
shader_type canvas_item;

uniform vec4 shadow_color : source_color = vec4(0.0, 0.0, 0.0, 0.58);
uniform bool invert_gradient = false;

void fragment() {
	float amount = 1.0 - UV.y;
	if (invert_gradient) {
		amount = UV.y;
	}
	float alpha = pow(amount, 1.35) * shadow_color.a;
	COLOR = vec4(shadow_color.rgb, alpha);
}
"

[sub_resource type="ShaderMaterial" id="ShaderMaterial_2sfso"]
shader = SubResource("Shader_pyddu")
shader_parameter/shadow_color = Color(0, 0, 0, 0.58)
shader_parameter/invert_gradient = false

